class Solution:
    def findMinDiff(self, arr, M):
        n = len(arr)
        
        # If students are more than packets
        if M > n:
            return 0
        
        # Sort the array
        arr.sort()
        
        min_diff = float('inf')
        
        # Sliding window of size M
        for i in range(n - M + 1):
            diff = arr[i + M - 1] - arr[i]
            min_diff = min(min_diff, diff)
        
        return min_diff

